generator client {
  provider     = "prisma-client"
  output       = "../lib/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum QuestionSetOrigin {
  CURATED      @map("curated")
  AI_GENERATED @map("ai_generated")

  @@map("question_set_origin")
}

enum PublishStatus {
  DRAFT     @map("draft")
  REVIEWING @map("reviewing")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")

  @@map("publish_status")
}

enum Difficulty {
  EASY   @map("easy")
  MEDIUM @map("medium")
  HARD   @map("hard")

  @@map("difficulty")
}

enum Verdict {
  LEGIT @map("legit")
  SUS   @map("sus")

  @@map("verdict")
}

enum ReviewStatus {
  DRAFT    @map("draft")
  APPROVED @map("approved")
  REJECTED @map("rejected")

  @@map("review_status")
}

model Topic {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String     @unique @db.VarChar(80)
  name      String     @unique @db.VarChar(120)
  isActive  Boolean    @default(true) @map("is_active")
  questions Question[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("topics")
}

model QuestionSet {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key            String            @unique @db.VarChar(120)
  title          String            @db.VarChar(160)
  schemaVersion  String            @map("schema_version") @db.VarChar(20)
  datasetVersion String?           @map("dataset_version") @db.VarChar(40)
  origin         QuestionSetOrigin
  status         PublishStatus     @default(DRAFT)
  topicPrompt    String?           @map("topic_prompt") @db.VarChar(160)
  publishedAt    DateTime?         @map("published_at") @db.Timestamptz(3)
  questions      Question[]
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, origin])
  @@map("question_sets")
}

model Question {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key           String             @unique @db.VarChar(160)
  questionSetId String             @map("question_set_id") @db.Uuid
  topicId       String             @map("topic_id") @db.Uuid
  difficulty    Difficulty
  prompt        String             @db.Text
  context       String?            @db.Text
  position      Int
  reviewStatus  ReviewStatus       @default(DRAFT) @map("review_status")
  isActive      Boolean            @default(true) @map("is_active")
  questionSet   QuestionSet        @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  topic         Topic              @relation(fields: [topicId], references: [id], onDelete: Restrict)
  answers       Answer[]
  reference     QuestionReference?
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([questionSetId, topicId, position])
  @@index([topicId, difficulty, isActive])
  @@index([questionSetId, reviewStatus])
  @@map("questions")
}

model Answer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId    String   @map("question_id") @db.Uuid
  key           String   @db.VarChar(20)
  position      Int
  text          String   @db.Text
  verdict       Verdict
  feedbackLegit String   @map("feedback_legit") @db.Text
  feedbackSus   String   @map("feedback_sus") @db.Text
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([questionId, key])
  @@unique([questionId, position])
  @@map("answers")
}

model QuestionReference {
  questionId String   @id @map("question_id") @db.Uuid
  title      String   @db.VarChar(240)
  url        String   @db.VarChar(2048)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("question_references")
}

model LearnerProfile {
  userId          String                @id @map("user_id") @db.Uuid
  timezone        String                @default("UTC") @db.VarChar(64)
  questionStates  UserQuestionState[]
  attempts        QuestionAttempt[]
  savedQuestions  UserSavedQuestion[]
  dailyProgress   UserDailyProgress[]
  subjectProgress UserSubjectProgress[]
  recoveryGrants  PasswordRecoveryGrant[]
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("learner_profiles")
}

model PasswordRecoveryGrant {
  tokenHash  String         @id @map("token_hash") @db.Char(64)
  userId     String         @map("user_id") @db.Uuid
  expiresAt  DateTime       @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime?      @map("consumed_at") @db.Timestamptz(3)
  profile    LearnerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([userId, expiresAt])
  @@map("password_recovery_grants")
}

model UserQuestionState {
  userId           String         @map("user_id") @db.Uuid
  questionKey      String         @map("question_key") @db.VarChar(160)
  topic            String         @db.VarChar(120)
  totalAttempts    Int            @default(0) @map("total_attempts")
  lastScore        Int?           @map("last_score") @db.SmallInt
  reviewStage      Int            @default(0) @map("review_stage") @db.SmallInt
  everPerfect      Boolean        @default(false) @map("ever_perfect")
  firstAttemptedAt DateTime?      @map("first_attempted_at") @db.Timestamptz(3)
  lastAttemptedAt  DateTime?      @map("last_attempted_at") @db.Timestamptz(3)
  nextReviewAt     DateTime?      @map("next_review_at") @db.Timestamptz(3)
  profile          LearnerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([userId, questionKey])
  @@index([userId, nextReviewAt])
  @@index([userId, topic, everPerfect])
  @@map("user_question_states")
}

model QuestionAttempt {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  questionKey String         @map("question_key") @db.VarChar(160)
  topic       String         @db.VarChar(120)
  decisions   Json
  score       Int            @db.SmallInt
  total       Int            @default(3) @db.SmallInt
  isPerfect   Boolean        @map("is_perfect")
  profile     LearnerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([userId, createdAt])
  @@index([userId, questionKey, createdAt])
  @@map("question_attempts")
}

model UserSavedQuestion {
  userId      String         @map("user_id") @db.Uuid
  questionKey String         @map("question_key") @db.VarChar(160)
  profile     LearnerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  @@id([userId, questionKey])
  @@index([userId, createdAt])
  @@map("user_saved_questions")
}

model UserDailyProgress {
  userId       String         @map("user_id") @db.Uuid
  dateKey      String         @map("date_key") @db.VarChar(10)
  perfectCount Int            @default(0) @map("perfect_count")
  profile      LearnerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([userId, dateKey])
  @@index([userId, dateKey])
  @@map("user_daily_progress")
}

model UserSubjectProgress {
  userId          String         @map("user_id") @db.Uuid
  topic           String         @db.VarChar(120)
  perfectQuestions Int           @default(0) @map("perfect_questions")
  profile         LearnerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([userId, topic])
  @@index([userId, perfectQuestions])
  @@map("user_subject_progress")
}
