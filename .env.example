# Question content source. Use "mock" without PostgreSQL, "postgres" to require
# the database, or "auto" to use PostgreSQL only when DATABASE_URL is present.
QUESTION_DATA_SOURCE=mock

# Local Docker default. In hosted environments use a TLS-enabled, pooled runtime
# URL here and DIRECT_DATABASE_URL for migrations when the provider supplies one.
DATABASE_URL=postgresql://studyscroll:studyscroll_dev@localhost:5432/studyscroll?schema=public
DIRECT_DATABASE_URL=postgresql://studyscroll:studyscroll_dev@localhost:5432/studyscroll?schema=public

# Canonical public origin used to verify state-changing browser requests.
# Set this to the deployed HTTPS origin in production.
APP_ORIGIN=

# Server only. Never expose this with a NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=

# Keep false until authentication, premium entitlements, and distributed rate
# limiting are implemented. The current endpoint also fails closed internally.
AI_QUESTION_GENERATION_ENABLED=false

# Use a random value of at least 32 characters in deployed environments.
AI_SAFETY_HMAC_SECRET=

# Current defaults. Pin a snapshot after production evaluations if stability is
# more important than automatically receiving model improvements.
AI_GENERATION_MODEL=gpt-5.6-sol
AI_REVIEW_MODEL=gpt-5.6-sol
AI_GATE_MODEL=gpt-5.6-terra
